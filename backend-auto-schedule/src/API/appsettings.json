{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=autoSchedule;Username=postgres;Password=postgres"
  },
  "Solver": {
    "MaxTimeInSeconds": 180,
    "SearchWorkers": 8,
    "LogSearchProgress": false
  },
  "Mmis": {
    "Enabled": true,
    "RunOnStartup": true,
    "SyncAtTime": "03:00",
    "ConnectionString": ""
  },
  "ActiveDirectory": {
    "Host": "localhost",
    "Port": 636,
    "UseSsl": true,
    "IgnoreCertificateErrors": true,
    "Realm": "TEST.MC",
    "BaseDn": "DC=test,DC=mc",
    "RequiredGroup": "ScheduleBureau"
  },
  "Jwt": {
    "Issuer": "auto-schedule",
    "Audience": "auto-schedule",
    "SigningKey": "dev-only-change-me-please-use-a-32+byte-secret-key",
    "ExpiryMinutes": 480
  }
}
