{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "_comment": "Задаётся через env (ConnectionStrings__DefaultConnection) или appsettings.Development.json.",
    "DefaultConnection": ""
  },
  "Database": {
    "_comment": "Применять миграции при старте. true — для dev/docker; в строгом prod выключить и мигрировать отдельным шагом.",
    "MigrateOnStartup": true
  },
  "Solver": {
    "_comment": "MaxTimeInSeconds — общий бюджет на институт (делится между подзадачами декомпозиции). SearchWorkers держим небольшим: каждый воркер CP-SAT держит копию модели, что кратно увеличивает память.",
    "MaxTimeInSeconds": 1800,
    "SearchWorkers": 2,
    "LogSearchProgress": false
  },
  "Mmis": {
    "Enabled": true,
    "RunOnStartup": true,
    "SyncAtTime": "03:00",
    "ConnectionString": ""
  },
  "InfrastructureSeed": {
    "Enabled": true,
    "SeedFacilities": true,
    "SeedCalendarGrid": true,
    "SeedEquipment": true,
    "SeedConstraintWeights": true,
    "EquipRoomsFraction": 0.4,
    "WorkingDays": 6,
    "PairsPerDay": 8
  },
  "ActiveDirectory": {
    "Host": "localhost",
    "Port": 636,
    "UseSsl": true,
    "IgnoreCertificateErrors": true,
    "Realm": "TEST.MC",
    "BaseDn": "DC=test,DC=mc",
    "RequiredGroup": "ScheduleBureau"
  },
  "Jwt": {
    "Issuer": "auto-schedule",
    "Audience": "auto-schedule",
    "_comment": "SigningKey задаётся через env (Jwt__SigningKey) или appsettings.Development.json. Пустой в prod => приложение не стартует.",
    "SigningKey": "",
    "ExpiryMinutes": 480
  }
}
