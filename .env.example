# Скопируйте в .env и при необходимости поменяйте значения.

# --- PostgreSQL ---
POSTGRES_DB=autoSchedule
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Порты, публикуемые на хосте ---
DB_PORT=5432
BACKEND_PORT=5000
FRONTEND_PORT=8080

# --- Окружение бэкенда ---
ASPNETCORE_ENVIRONMENT=Production

# --- MMIS (имитация исходной БД MS SQL) ---
# Пароль должен быть «сильным»: длина 8+, верхний/нижний регистр, цифра, спецсимвол.
MMIS_SA_PASSWORD=Mmis_Str0ng_Pass!
MMIS_PORT=1433
