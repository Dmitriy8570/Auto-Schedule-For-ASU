# Скопируйте в .env и при необходимости поменяйте значения.

# --- PostgreSQL ---
POSTGRES_DB=autoSchedule
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Порты, публикуемые на хосте ---
DB_PORT=5432
BACKEND_PORT=5000
FRONTEND_PORT=8080

# --- Окружение бэкенда ---
ASPNETCORE_ENVIRONMENT=Production

# --- MMIS (имитация исходной БД MS SQL) ---
# Пароль должен быть «сильным»: длина 8+, верхний/нижний регистр, цифра, спецсимвол.
MMIS_SA_PASSWORD=Mmis_Str0ng_Pass!
MMIS_PORT=1433

# --- Active Directory (Samba AD DC) ---
AD_REALM=TEST.MC
AD_DOMAIN=TEST
AD_ADMIN_PASSWORD=P@ssw0rd2024!
# Группа «Бюро расписаний» (samAccountName латиницей для LDAP/RequiredGroup).
AD_GROUP=ScheduleBureau
AD_GROUP_DESC=Бюро расписаний
# Единственный пользователь домена.
AD_USER=i.petrov
AD_USER_PASSWORD=Schedule2024!
# Порты, публикуемые на хосте.
AD_LDAP_PORT=389
AD_LDAPS_PORT=636
AD_KERBEROS_PORT=88
